APP_NAME=Research Agent
DATABASE_PATH=data/research_agent.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OpenAI-compatible endpoint; local Ollama/vLLM gateways can override this value.
OPENAI_BASE_URL=https://api.openai.com/v1
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_NAME=Research Agent
FEISHU_ENABLE_SIGNATURE_CHECK=false

# RAG 检索模式：keyword 保留旧关键词检索；hybrid 使用本地轻量混合检索
RAG_RETRIEVAL_MODE=hybrid
# RAG embedding provider：默认 hash；可选 sentence-transformers
RAG_EMBEDDING_PROVIDER=hash
# hash embedding 维度
RAG_EMBEDDING_DIM=256
# 可选 sentence-transformers provider 配置
RAG_SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_SENTENCE_TRANSFORMERS_DEVICE=auto
RAG_EMBEDDING_BATCH_SIZE=32
# Reciprocal Rank Fusion 的 k 参数
RAG_RRF_K=60
# 是否启用确定性轻量 reranker
RAG_RERANK_ENABLED=true
# Context Pack 粗略 token 预算
RAG_CONTEXT_TOKEN_BUDGET=6000
# RAG 回答模式：auto（有 API key 时启用 LLM）/ llm / template
RAG_ANSWER_MODE=auto
