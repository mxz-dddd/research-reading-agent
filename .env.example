APP_NAME=Research Agent
DATABASE_PATH=data/research_agent.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible endpoint; local Ollama/vLLM gateways can override this value.
OPENAI_BASE_URL=https://api.openai.com/v1
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_NAME=Research Agent
# 本地联调可保持 false；生产部署建议设为 true，并配置上面的 FEISHU_ENCRYPT_KEY。
FEISHU_ENABLE_SIGNATURE_CHECK=false

# RAG 检索模式：keyword 保留旧关键词检索；hybrid 使用本地轻量混合检索
RAG_RETRIEVAL_MODE=hybrid
# RAG embedding provider：默认 hash；可选 sentence-transformers
RAG_EMBEDDING_PROVIDER=hash
# hash embedding 维度
RAG_EMBEDDING_DIM=256
# 可选 sentence-transformers provider 配置
RAG_SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_SENTENCE_TRANSFORMERS_DEVICE=auto
RAG_EMBEDDING_BATCH_SIZE=32
# Reciprocal Rank Fusion 的 k 参数
RAG_RRF_K=60
# 是否启用确定性轻量 reranker
RAG_RERANK_ENABLED=true
# reranker provider：deterministic（默认）/ cross-encoder（需可选依赖）
RAG_RERANK_PROVIDER=deterministic
RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Context Pack 粗略 token 预算
RAG_CONTEXT_TOKEN_BUDGET=6000
# RAG 回答模式：auto（有 API key 时启用 LLM）/ llm / template
RAG_ANSWER_MODE=auto
# 本地向量缓存：sqlite（默认，索引期预计算 embedding 并缓存）/ none / chroma（需可选依赖）
RAG_VECTOR_STORE=sqlite
RAG_CHROMA_PERSIST_DIRECTORY=data/chroma

# 可选 multi-step Agent；默认保持 single-step
AGENT_MULTI_STEP_ENABLED=false
AGENT_MAX_STEPS=3

# 多轮连续对话上下文
CONVERSATION_CONTEXT_ENABLED=true
CONVERSATION_TTL_HOURS=168
CONVERSATION_MAX_TURNS=10
CONVERSATION_MAX_RESULT_REFS=20
